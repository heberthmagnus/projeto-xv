generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PreferredPosition {
  GOLEIRO
  LATERAL
  ZAGUEIRO
  VOLANTE
  MEIA
  ATACANTE
}

enum PlayerLevel {
  A
  B
  C
  D
  E
}

enum PaymentStatus {
  PENDENTE
  PAGO
}

enum ChampionshipFormat {
  PONTOS_CORRIDOS
  MATA_MATA
  MISTO
}

enum ChampionshipStatus {
  RASCUNHO
  ATIVO
  FINALIZADO
  CANCELADO
}

enum ChampionshipRegistrationMode {
  INDIVIDUAL
  POR_EQUIPES
  FECHADO
}

enum ChampionshipStageType {
  RODADA
  GRUPO
  QUARTAS
  SEMIFINAL
  FINAL
  OUTRO
}

enum MatchStatus {
  AGENDADO
  EM_ANDAMENTO
  FINALIZADO
  CANCELADO
}

enum MatchEventType {
  GOL
  CARTAO_AMARELO
  CARTAO_VERMELHO
  OBSERVACAO
}

enum StandingMovement {
  SUBIU
  CAIU
  MANTEVE
}

enum ChampionshipPlayerStatus {
  ATIVO
  RESERVA
  INATIVO
}

enum PeladaType {
  CAMPINHO
  CAMPAO
}

enum FirstGameRule {
  SORTEIO
  ORDEM_DE_CHEGADA
}

enum PeladaStatus {
  ABERTA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
}

enum GoalkeeperSide {
  GOLEIRO_A
  GOLEIRO_B
}

enum PeladaTeamColor {
  AMARELO
  PRETO
}

enum PeladaRoundStatus {
  ATIVA
  FINALIZADA
}

enum PeladaRoundPlayerSource {
  FILA
  REPESCAGEM
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
}

model Championship {
  id               String                       @id @default(uuid())
  name             String
  slug             String                       @unique
  seasonLabel      String?
  description      String?
  format           ChampionshipFormat           @default(PONTOS_CORRIDOS)
  status           ChampionshipStatus           @default(RASCUNHO)
  registrationMode ChampionshipRegistrationMode @default(INDIVIDUAL)
  startsAt         DateTime?
  endsAt           DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @default(now()) @updatedAt

  teams         ChampionshipTeam[]
  players       ChampionshipPlayer[]
  stages        ChampionshipStage[]
  matches       Match[]
  standings     Standing[]
  registrations Registration[]
}

model Team {
  id             String   @id @default(uuid())
  name           String
  slug           String?  @unique
  shortName      String?
  crestUrl       String?
  primaryColor   String?
  secondaryColor String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  championships ChampionshipTeam[]
  homeMatches   Match[] @relation("HomeTeam")
  awayMatches   Match[] @relation("AwayTeam")
  standings     Standing[]
  events        MatchEvent[]
  players       ChampionshipPlayer[]
}

model ChampionshipTeam {
  id             String  @id @default(uuid())
  championshipId String
  teamId         String
  groupLabel     String?
  seed           Int?
  displayOrder   Int?

  championship Championship @relation(fields: [championshipId], references: [id])
  team         Team         @relation(fields: [teamId], references: [id])

  @@unique([championshipId, teamId])
}

model ChampionshipStage {
  id             String              @id @default(uuid())
  championshipId String
  name           String
  order          Int
  stageType      ChampionshipStageType
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  matches      Match[]

  @@unique([championshipId, order])
}

model ChampionshipPlayer {
  id             String                  @id @default(uuid())
  championshipId String
  registrationId String                  @unique
  teamId         String?
  squadNumber    Int?
  rosterOrder    Int?
  status         ChampionshipPlayerStatus @default(ATIVO)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @default(now()) @updatedAt

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([championshipId, teamId])
  @@index([teamId])
}

model Match {
  id             String   @id @default(uuid())
  championshipId String
  stageId        String?
  homeTeamId     String
  awayTeamId     String

  homeScore   Int         @default(0)
  awayScore   Int         @default(0)
  round       Int
  roundNumber Int?
  scheduledAt DateTime?
  location    String?
  status      MatchStatus @default(AGENDADO)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt

  championship Championship @relation(fields: [championshipId], references: [id])
  stage        ChampionshipStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  homeTeam Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayTeam", fields: [awayTeamId], references: [id])

  events MatchEvent[]
}

model Standing {
  id             String @id @default(uuid())
  championshipId String
  teamId         String

  points         Int             @default(0)
  gamesPlayed    Int             @default(0)
  wins           Int             @default(0)
  draws          Int             @default(0)
  losses         Int             @default(0)
  goalsFor       Int             @default(0)
  goalsAgainst   Int             @default(0)
  goalDifference Int             @default(0)
  winRate        Int             @default(0)
  rank           Int?
  movement       StandingMovement @default(MANTEVE)

  championship Championship @relation(fields: [championshipId], references: [id])
  team         Team         @relation(fields: [teamId], references: [id])

  @@unique([championshipId, teamId])
}

model MatchEvent {
  id      String         @id @default(uuid())
  matchId String
  teamId  String?
  player  String
  type    MatchEventType
  minute  Int?
  notes   String?

  match Match @relation(fields: [matchId], references: [id])
  team  Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

model Registration {
  id                String            @id @default(uuid())
  championshipId    String

  fullName          String
  nickname          String?
  preferredPosition PreferredPosition
  birthDate         DateTime
  phone             String
  email             String?
  level             PlayerLevel?
  paymentStatus     PaymentStatus     @default(PENDENTE)
  paidAt            DateTime?

  confirmedRules    Boolean
  createdAt         DateTime          @default(now())

  championship Championship @relation(fields: [championshipId], references: [id])
  championshipPlayer ChampionshipPlayer?

  @@index([championshipId])
}

model Pelada {
  id                  String         @id @default(uuid())
  scheduledAt         DateTime
  type                PeladaType
  firstGameRule       FirstGameRule
  arrivalCutoffTime   String?
  maxFirstGamePlayers Int?
  linePlayersCount    Int
  status              PeladaStatus   @default(ABERTA)
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  confirmations       PeladaConfirmation[]
  arrivals            PeladaArrival[]
  teamAssignments     PeladaTeamAssignment[]
  rounds              PeladaRound[]

  @@index([scheduledAt])
  @@index([status])
}

model PeladaConfirmation {
  id               String            @id @default(uuid())
  peladaId         String
  parentConfirmationId String?
  fullName         String
  preferredPosition PreferredPosition
  age              Int?
  level            PlayerLevel?
  guestCount       Int               @default(0)
  goalkeeperSide   GoalkeeperSide?
  createdByAdmin   Boolean           @default(false)
  guestOrder       Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  pelada           Pelada            @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  arrivals         PeladaArrival[]
  parentConfirmation PeladaConfirmation? @relation("PeladaConfirmationGuests", fields: [parentConfirmationId], references: [id], onDelete: Cascade)
  guests           PeladaConfirmation[] @relation("PeladaConfirmationGuests")

  @@index([peladaId])
  @@index([parentConfirmationId])
  @@unique([parentConfirmationId, guestOrder])
}

model PeladaArrival {
  id               String            @id @default(uuid())
  peladaId         String
  confirmationId   String?
  fullName         String
  isGuest          Boolean           @default(false)
  guestInvitedBy   String?
  preferredPosition PreferredPosition
  age              Int?
  arrivedAt        DateTime          @default(now())
  arrivalOrder     Int
  playsFirstGame   Boolean           @default(false)
  playsSecondGame  Boolean           @default(false)
  availableForNextRound Boolean      @default(false)
  level            PlayerLevel?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  pelada           Pelada            @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  confirmation     PeladaConfirmation? @relation(fields: [confirmationId], references: [id], onDelete: Cascade)
  teamAssignment   PeladaTeamAssignment?
  roundPlayers     PeladaRoundPlayer[]

  @@index([peladaId])
  @@index([confirmationId])
  @@unique([peladaId, arrivalOrder])
}

model PeladaTeamAssignment {
  id               String          @id @default(uuid())
  peladaId         String
  arrivalId        String          @unique
  teamColor        PeladaTeamColor
  assignedPosition PreferredPosition?
  isFallback       Boolean         @default(false)
  displayOrder     Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  pelada           Pelada          @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  arrival          PeladaArrival   @relation(fields: [arrivalId], references: [id], onDelete: Cascade)

  @@index([peladaId, teamColor])
  @@unique([peladaId, teamColor, displayOrder])
}

model PeladaRound {
  id               String                 @id @default(uuid())
  peladaId         String
  roundNumber      Int
  status           PeladaRoundStatus      @default(ATIVA)
  blackScore       Int                    @default(0)
  yellowScore      Int                    @default(0)
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  pelada           Pelada                 @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  players          PeladaRoundPlayer[]
  goals            PeladaRoundGoal[]

  @@unique([peladaId, roundNumber])
  @@index([peladaId, status])
}

model PeladaRoundPlayer {
  id               String                 @id @default(uuid())
  roundId          String
  arrivalId        String
  source           PeladaRoundPlayerSource
  teamColor        PeladaTeamColor?
  queueOrder       Int
  createdAt        DateTime               @default(now())

  round            PeladaRound             @relation(fields: [roundId], references: [id], onDelete: Cascade)
  arrival          PeladaArrival           @relation(fields: [arrivalId], references: [id], onDelete: Cascade)
  goals            PeladaRoundGoal[]

  @@unique([roundId, arrivalId])
  @@unique([roundId, queueOrder])
  @@index([arrivalId])
}

model PeladaRoundGoal {
  id               String          @id @default(uuid())
  roundId          String
  roundPlayerId    String?
  scorerName       String
  teamColor        PeladaTeamColor
  minute           Int?
  createdAt        DateTime        @default(now())

  round            PeladaRound     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundPlayer      PeladaRoundPlayer? @relation(fields: [roundPlayerId], references: [id])

  @@index([roundPlayerId])
  @@index([roundId, teamColor])
}
