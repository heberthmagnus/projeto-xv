generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PreferredPosition {
  GOLEIRO
  LATERAL
  ZAGUEIRO
  VOLANTE
  MEIA
  ATACANTE
}

enum PlayerLevel {
  A
  B
  C
  D
  E
}

enum PaymentStatus {
  PENDENTE
  PAGO
}

enum PeladaType {
  CAMPINHO
  CAMPAO
}

enum FirstGameRule {
  SORTEIO
  ORDEM_DE_CHEGADA
}

enum PeladaStatus {
  ABERTA
  EM_ANDAMENTO
  FINALIZADA
  CANCELADA
}

enum GoalkeeperSide {
  GOLEIRO_A
  GOLEIRO_B
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
}

model Championship {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  teams         ChampionshipTeam[]
  matches       Match[]
  standings     Standing[]
  registrations Registration[]
}

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  championships ChampionshipTeam[]
  homeMatches   Match[] @relation("HomeTeam")
  awayMatches   Match[] @relation("AwayTeam")
  standings     Standing[]
}

model ChampionshipTeam {
  id             String @id @default(uuid())
  championshipId String
  teamId         String

  championship Championship @relation(fields: [championshipId], references: [id])
  team         Team         @relation(fields: [teamId], references: [id])

  @@unique([championshipId, teamId])
}

model Match {
  id             String   @id @default(uuid())
  championshipId String
  homeTeamId     String
  awayTeamId     String

  homeScore Int @default(0)
  awayScore Int @default(0)

  round Int

  createdAt DateTime @default(now())

  championship Championship @relation(fields: [championshipId], references: [id])

  homeTeam Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayTeam", fields: [awayTeamId], references: [id])

  events MatchEvent[]
}

model Standing {
  id             String @id @default(uuid())
  championshipId String
  teamId         String

  points       Int @default(0)
  wins         Int @default(0)
  draws        Int @default(0)
  losses       Int @default(0)
  goalsFor     Int @default(0)
  goalsAgainst Int @default(0)

  championship Championship @relation(fields: [championshipId], references: [id])
  team         Team         @relation(fields: [teamId], references: [id])

  @@unique([championshipId, teamId])
}

model MatchEvent {
  id      String @id @default(uuid())
  matchId String
  player  String
  type    String

  match Match @relation(fields: [matchId], references: [id])
}

model Registration {
  id                String            @id @default(uuid())
  championshipId    String

  fullName          String
  nickname          String?
  preferredPosition PreferredPosition
  birthDate         DateTime
  phone             String
  email             String?
  level             PlayerLevel?
  paymentStatus     PaymentStatus     @default(PENDENTE)
  paidAt            DateTime?

  confirmedRules    Boolean
  createdAt         DateTime          @default(now())

  championship Championship @relation(fields: [championshipId], references: [id])

  @@index([championshipId])
}

model Pelada {
  id                  String         @id @default(uuid())
  scheduledAt         DateTime
  type                PeladaType
  firstGameRule       FirstGameRule
  arrivalCutoffTime   String?
  maxFirstGamePlayers Int?
  linePlayersCount    Int
  status              PeladaStatus   @default(ABERTA)
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  confirmations       PeladaConfirmation[]
  arrivals            PeladaArrival[]

  @@index([scheduledAt])
  @@index([status])
}

model PeladaConfirmation {
  id               String            @id @default(uuid())
  peladaId         String
  fullName         String
  preferredPosition PreferredPosition
  age              Int
  guestCount       Int               @default(0)
  goalkeeperSide   GoalkeeperSide?
  createdByAdmin   Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  pelada           Pelada            @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  arrivals         PeladaArrival[]

  @@index([peladaId])
}

model PeladaArrival {
  id               String            @id @default(uuid())
  peladaId         String
  confirmationId   String?
  fullName         String
  preferredPosition PreferredPosition
  age              Int
  arrivalOrder     Int
  playsFirstGame   Boolean           @default(false)
  playsSecondGame  Boolean           @default(false)
  level            PlayerLevel?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  pelada           Pelada            @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  confirmation     PeladaConfirmation? @relation(fields: [confirmationId], references: [id], onDelete: Cascade)

  @@index([peladaId])
  @@index([confirmationId])
  @@unique([peladaId, arrivalOrder])
}
